{
  "uid": "test-dashboard-blocky",
  "title": "[TEST] blocky",
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {
    "hidden": false,
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 0,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": null
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "blocky_build_info",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "Version",
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^version$/"
        },
        "showPercentChange": false,
        "orientation": ""
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(up{job=~\"$job\"})",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "State",
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showPercentChange": false,
        "orientation": ""
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Activity",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 0,
      "panels": null
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (client) (rate(blocky_query_total[$__rate_interval])) * 60",
          "legendFormat": "{{ client }}"
        }
      ],
      "title": "Request rate per client",
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": null
        },
        "tooltip": {
          "mode": "",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": null
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (type) (rate(blocky_query_total[$__rate_interval])) * 60",
          "legendFormat": "{{ type }}"
