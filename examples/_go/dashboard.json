    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(\n  (1 - sum without (mode) (rate(node_cpu_seconds_total{job=\"integrations/raspberrypi-node\", mode=~\"idle|iowait|steal\", instance=\"$instance\"}[$__rate_interval])))\n/ ignoring(cpu) group_left\n  count without (cpu, mode) (node_cpu_seconds_total{job=\"integrations/raspberrypi-node\", mode=\"idle\", instance=\"$instance\"})\n)",
          "legendFormat": "{{ cpu }}"
        }
      ],
      "title": "CPU Usage",
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 18,
        "x": 0,
        "y": 1
