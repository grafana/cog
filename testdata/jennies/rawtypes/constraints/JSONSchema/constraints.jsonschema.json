{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "SomeStruct": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "greaterThanZero",
        "negative",
        "title",
        "labels",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 5,
          "exclusiveMaximum": 10
        },
        "maybeId": {
          "type": "integer",
          "minimum": 5,
          "exclusiveMaximum": 10
        },
        "greaterThanZero": {
          "type": "integer",
          "minimum": 0,
          "exclusiveMaximum": 3
        },
        "negative": {
          "type": "integer",
          "minimum": -19,
          "exclusiveMaximum": 10
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}