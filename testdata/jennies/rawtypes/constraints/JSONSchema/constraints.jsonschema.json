{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "SomeStruct": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "greaterThanZero",
        "negative",
        "title",
        "labels",
        "tags",
        "regex",
        "negativeRegex",
        "minMaxList",
        "uniqueList",
        "fullConstraintList"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 5,
          "exclusiveMaximum": 10
        },
        "maybeId": {
          "type": "integer",
          "minimum": 5,
          "exclusiveMaximum": 10
        },
        "greaterThanZero": {
          "type": "integer",
          "exclusiveMaximum": 3
        },
        "negative": {
          "type": "integer",
          "minimum": -19,
          "exclusiveMaximum": 10
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "regex": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "negativeRegex": {
          "type": "string",
          "not": {
            "pattern": "^[a-zA-Z0-9_-]+$"
          }
        },
        "minMaxList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 64
        },
        "uniqueList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "fullConstraintList": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 2,
          "maxItems": 10,
          "uniqueItems": true
        }
      }
    }
  }
}