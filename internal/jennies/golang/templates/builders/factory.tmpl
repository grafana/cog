{{- define "factory" }}
{{- $builderPkg := .Factory.BuilderRef.ReferredPkg|importPkg -}}
{{- range .Factory.Comments }}
// {{ . }}
{{- end }}
func {{ .Factory.Name }}({{- template "args" .Factory.Args }}) *{{- if ne $builderPkg "" -}}{{ $builderPkg }}.{{- end -}}{{ .Factory.BuilderRef.ReferredType }}Builder {
	builder := {{ if ne $builderPkg "" -}}{{ $builderPkg }}.{{- end -}}New{{ .Factory.BuilderRef.ReferredType }}Builder()

{{- range $call := .Factory.OptionCalls }}
    {{ template "factory_option_call" (dict "Factory" $.Factory "Call" $call) }}
{{- end }}

	return builder
}
{{- end }}

{{- define "factory_option_call" }}
	{{- template "factory_option_call_prepare_parameters" (dict "Factory" .Factory "Call" .Call) }}
	builder.{{ .Call.Name }}({{- range $i, $param := .Call.Parameters }}{{- if gt $i 0 }}, {{ end }}{{ template "factory_parameter_value" (dict "Value" $param) -}}{{- end }})
{{- end }}

{{- define "factory_option_call_prepare_parameters" }}
{{- range $i, $param := .Call.Parameters }}
{{- if and (not (eq $param.Argument nil)) $param.ForceBuild -}}
	{{- $param.Argument.Name -}}Resource, err := {{- $param.Argument.Name -}}.Build()
	if err != nil {
		builder.RecordError("{{ $.Factory.Name }}({{ $param.Argument.Name }})", err)
		return builder
	}
{{- end -}}
{{- end -}}
{{- end }}

{{- define "factory_parameter_value" }}
	{{- if not (eq .Value.Constant nil) -}}
		{{- formatValue .Value.Constant.Type .Value.Constant.Value }}
	{{- end }}
	{{- if not (eq .Value.Argument nil) -}}
		{{- .Value.Argument.Name -}}{{- if .Value.ForceBuild -}}Resource{{- end -}}
	{{- end -}}
	{{- with .Value.Factory -}}
		{{- $pkg := .Ref.Package|importPkg -}}
		{{- if ne $pkg "" -}}{{ $pkg }}.{{- end -}}
		{{ .Ref.Factory }}({{ range $i, $arg := .Parameters }}{{- if gt $i 0 }}, {{ end }}{{ template "factory_parameter_value" (dict "Value" $arg)}}{{ end }})
	{{- end -}}
{{- end }}
