{{- $json := importStdPkg "encoding/json" -}}
// MarshalJSON implements a custom JSON marshalling logic to encode `{{ .def.Name }}` as JSON.
func (resource {{ .def.Name }}) MarshalJSON() ([]byte, error) {
{{- range .def.Type.Struct.Fields }}
	if resource.{{ .Name }} != nil {
		return json.Marshal(resource.{{ .Name }})
	}
{{ end }}

	return []byte("null"), nil
}
