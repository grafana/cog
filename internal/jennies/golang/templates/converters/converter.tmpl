package {{ .Converter.Package | formatPackageName }}

import (
    "fmt"
    "strings"
)

{{- define "guard" }}
    {{- if .NotNull -}}
        input.{{ .Path | formatPath }} != nil
    {{- else -}}
        {{ .Path.Last.Type | maybeDereference }}input.{{ .Path | formatPath }} {{ .Op }} {{ .Value }}
    {{- end -}}
{{- end }}

{{- define "guards" }}
    {{- $guardsCount := (sub (len .) 1) -}}
    {{- range $i, $guard := . }}{{- template "guard" $guard }}{{ if ne $i $guardsCount }} && {{ end }}{{ end }}
{{- end }}

{{- define "arg" -}}
    {{- if ne .Arg.Builder nil -}}
    {{ .Arg.Builder.Name }}Converter({{- if not .Type.Nullable}}&{{ end }}{{ .Var }})
    {{- else -}}
    fmt.Sprintf("%#v", {{ .Type | maybeDereference }}{{ .Var }})
    {{- end -}}
{{- end }}

func {{ .Converter.Builder.Name }}Converter(input *{{ .Converter.Object.Name }}) string {
    {{- $constructorArgsCount := (sub (len .Converter.ConstructorArgs) 1) }}
    calls := []string{
        `{{ .Converter.Package|formatPackageName }}.New{{ .Converter.Builder.Name }}Builder({{ with .Converter.ConstructorArgs}}`+{{ range $i, $arg := . }}{{ $var := (print "input." (formatPath $arg.ValuePath)) }}{{ template "arg" (dict "Arg" $arg "Var" $var "Type" $arg.ValuePath.Last.Type) }}{{- if ne $i $constructorArgsCount }} + ", " +{{ end }}{{ end }}+`{{ end }})`,
    }

    {{- range .Converter.Mappings }}
    {{ with .Guards }}if {{ template "guards" . }}{{ end }}{
        var buffer strings.Builder

        {{ if .Repeat -}}
        {{- $arg := index .Args 0 -}}
        for _, item := range input.{{ $arg.ValuePath | formatPath }} {
            buffer.WriteString(`{{ .Option.Name | upperCamelCase }}(`)
            buffer.WriteString({{ template "arg" (dict "Arg" $arg "Var" "item" "Type" $arg.ValuePath.Last.Type.Array.ValueType) }})
            buffer.WriteString(")")

            calls = append(calls, buffer.String())
            buffer.Reset()
        }
        {{- else }}
        buffer.WriteString(`{{ .Option.Name | upperCamelCase }}(`)
        {{- $argsCount := (sub (len .Args) 1) -}}
        {{- range $i, $arg := .Args }}
            {{- $var := (print "input." (formatPath $arg.ValuePath)) }}
            buffer.WriteString({{ template "arg" (dict "Arg" $arg "Var" $var "Type" $arg.ValuePath.Last.Type) }})
            {{- if ne $i $argsCount }}
                buffer.WriteString(", ")
            {{- end }}
        {{- end }}
        buffer.WriteString(")")

        calls = append(calls, buffer.String())
        {{- end }}
    }
    {{- end }}

    return strings.Join(calls, ".\t\n")
}
