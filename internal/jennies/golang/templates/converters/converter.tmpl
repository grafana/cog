package {{ .Converter.Package | formatPackageName }}

import (
    "fmt"
    "strings"
)

{{- define "guard" }}
    {{- if .NotNull -}}
        input.{{ .Path | formatPath }} != nil
    {{- else -}}
        {{ .Path.Last.Type | maybeDereference }}input.{{ .Path | formatPath }} {{ .Op }} {{ .Value }}
    {{- end -}}
{{- end }}

{{- define "guards" }}
    {{- $guardsCount := (sub (len .) 1) -}}
    {{- range $i, $guard := . }}{{- template "guard" $guard }}{{ if ne $i $guardsCount }} && {{ end }}{{ end }}
{{- end }}

{{- define "arg" -}}
    {{- if ne .Builder nil -}}
    {{ .Builder.Name }}Converter({{ if not .ValuePath.Last.Type.Nullable}}&{{ end }}input.{{ .ValuePath | formatPath }})
    {{- else -}}
    fmt.Sprintf("%#v", {{ .ValuePath.Last.Type | maybeDereference }}input.{{ .ValuePath | formatPath }})
    {{- end -}}
{{- end }}

func {{ .Converter.Builder.Name }}Converter(input *{{ .Converter.Object.Name }}) string {
    {{- $constructorArgsCount := (sub (len .Converter.ConstructorArgs) 1) -}}
    calls := []string{
        `{{ .Converter.Package|formatPackageName }}.New{{ .Converter.Builder.Name }}Builder({{ with .Converter.ConstructorArgs}}`+{{ range $i, $arg := . }}{{ template "arg" $arg }}{{- if ne $i $constructorArgsCount }} + ", " +{{ end }}{{ end }}+`{{ end }})`,
    }

    {{- range .Converter.Mappings }}
    {{ with .Guards }}if {{ template "guards" . }}{{ end }}{
        var buffer strings.Builder

        buffer.WriteString(`{{ .Option.Name | upperCamelCase }}(`)
        {{- $argsCount := (sub (len .Args) 1) -}}
        {{- range $i, $arg := .Args }}
        buffer.WriteString({{ template "arg" $arg }})
        {{- if ne $i $argsCount }}
        buffer.WriteString(", ")
        {{- end }}
        {{- end }}
        buffer.WriteString(")")

        calls = append(calls, buffer.String())
    }
    {{- end }}

    return strings.Join(calls, ".\t\n")
}
