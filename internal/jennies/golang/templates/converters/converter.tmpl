package {{ .Converter.Package | formatPackageName }}

import (
    "fmt"
    "strings"
)

{{- define "guard" }}
    {{- if and (eq .Op "!=") (eq .Value nil) -}}
        input.{{ .Path | formatPath }} != nil
    {{- else -}}
        {{- $leftOperand := print (.Path.Last.Type | maybeDereference) "input." (.Path | formatPath) -}}
        {{- $operator := .Op -}}
        {{- if eq .Op "minLength" -}}
            {{- $leftOperand = print "len(" $leftOperand ")" -}}
            {{- $operator = ">=" -}}
        {{- end -}}
        {{- if eq .Op "maxLength" -}}
            {{- $leftOperand = print "len(" $leftOperand ")" -}}
            {{- $operator = "<=" -}}
        {{- end -}}
        {{- $leftOperand }} {{ $operator}} {{ .Value | formatScalar -}}
    {{- end -}}
{{- end }}

{{- define "guards" }}
    {{- $guardsCount := (sub (len .) 1) -}}
    {{- range $i, $guard := . }}{{- template "guard" $guard }}{{ if ne $i $guardsCount }} && {{ end }}{{ end }}
{{- end }}

{{- define "arg" -}}
    {{- if ne .Arg.Builder nil -}}
        {{ .Arg.Builder.Name }}Converter({{- if not .Type.Nullable}}&{{ end }}{{ .Var }})
    {{- else -}}
        fmt.Sprintf("%#v", {{ .Type | maybeDereference }}{{ .Var }})
    {{- end -}}
{{- end }}

{{- define "prepare_arg" -}}
    {{- if ne .Arg.Builder nil -}}
        {{ if .Type.IsArray }}
            tmp{{ .IntoVar }} := []string{}
            for i := range {{ .Var }} {
                tmp{{ .IntoVar }} = append(tmp{{ .IntoVar }}, {{ .Arg.Builder.Name }}Converter({{- if not .Type.Array.ValueType.Nullable}}&{{ end }}{{ .Var }}[i]))
            }
            {{ .IntoVar }} := "{{ .Type | formatType }}{" + strings.Join(tmp{{ .IntoVar }}, ",\n") + "}"
        {{ else }}
            {{ .IntoVar }} := {{ .Arg.Builder.Name }}Converter({{- if not .Type.Nullable}}&{{ end }}{{ .Var }})
        {{ end }}
    {{- else -}}
        {{ if .Type.IsRef }}
            {{ .IntoVar }} := fmt.Sprintf("%#v", {{ .Type | maybeDereference }}{{ .Var }}) // ref
        {{ else if .Type.IsStruct }}
            {{ .IntoVar }} := fmt.Sprintf("%#v", {{ .Type | maybeDereference }}{{ .Var }}) // struct
        {{ else }}
            {{ .IntoVar }} := fmt.Sprintf("%#v", {{ .Type | maybeDereference }}{{ .Var }})
        {{ end }}
    {{- end -}}
{{- end }}

func {{ .Converter.BuilderName }}Converter(input *{{ .Converter.For.Name }}) string {
    {{- $constructorArgsCount := (sub (len .Converter.ConstructorArgs) 1) }}
    calls := []string{
        `{{ .Converter.Package|formatPackageName }}.New{{ .Converter.BuilderName }}Builder({{ with .Converter.ConstructorArgs}}`+{{ range $i, $arg := . }}{{ $var := (print "input." (formatPath $arg.ValuePath)) }}{{ template "arg" (dict "Arg" $arg "Var" $var "Type" $arg.ValueType) }}{{- if ne $i $constructorArgsCount }} + ", " +{{ end }}{{ end }}+`{{ end }})`,
    }

    {{- range .Converter.Mappings }}
    {{ with .Guards }}if {{ template "guards" . }}{{ end }}{
        var buffer strings.Builder

        {{ if .Repeat -}}
        {{- $arg := index .Args 0 -}}
        for _, item := range input.{{ $arg.ValuePath | formatPath }} {
            buffer.WriteString(`{{ .Option.Name | upperCamelCase }}(`)
            {{ template "prepare_arg" (dict "IntoVar" "arg" "Arg" $arg "Var" "item" "Type" $arg.ValueType.Array.ValueType) }}
            buffer.WriteString(arg)
            buffer.WriteString(")")

            calls = append(calls, buffer.String())
            buffer.Reset()
        }
        {{- else }}
        buffer.WriteString(`{{ .Option.Name | upperCamelCase }}(`)
        {{- $argsCount := (sub (len .Args) 1) -}}
        {{- range $i, $arg := .Args }}
            {{- $var := print "input." (formatPath $arg.ValuePath) }}
            {{ template "prepare_arg" (dict "IntoVar" (print "arg" $i) "Arg" $arg "Var" $var "Type" $arg.ValueType) }}
            buffer.WriteString({{ print "arg" $i }})
            {{- if ne $i $argsCount }}
                buffer.WriteString(", ")
            {{- end }}
        {{- end }}
        buffer.WriteString(")")

        calls = append(calls, buffer.String())
        {{- end }}
    }
    {{- end }}

    return strings.Join(calls, ".\t\n")
}
